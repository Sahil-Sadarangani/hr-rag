# Copy this file to .env and add your key.
# Without this key, the app still runs in extractive demo mode.
OPENAI_API_KEY=your_openai_api_key_here

# You can change this to any OpenAI chat model available to your account.
OPENAI_MODEL=gpt-4o-mini

# Local embedding model used for vector search.
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
